{
  "contract_version": "0.1.0",
  "product": "connected-operations-intelligence",
  "owner": "data-products/io-reporting",
  "consumer": "apps/api",
  "rules": {
    "application_must_use_approved_consumption_views": true,
    "raw_silver_gold_access_from_app_forbidden": true
  },
  "contracts": [
    {
      "id": "warehouse360.overview",
      "version": "0.1.0",
      "domain": "warehouse",
      "owner": "warehouse-operations",
      "lifecycle": "draft",
      "description": "Overview metrics for the Warehouse 360 dashboard.",
      "source_view": "vw_consumption_warehouse360_overview",
      "grain": "one row per plant per refresh",
      "primary_key": [
        "plant_code"
      ],
      "freshness": {
        "expected_minutes": 15,
        "warning_minutes": 30,
        "critical_minutes": 60
      },
      "access_policy": {
        "row_level_key": "plant_code",
        "entitlement_source": "published.central_services.user_plant_access"
      },
      "fields": [
        {
          "name": "plant_code",
          "type": "string",
          "required": true,
          "description": "SAP plant code"
        },
        {
          "name": "occupancy_rate",
          "type": "double",
          "required": true,
          "unit": "percent",
          "description": "Percentage of occupied warehouse bins"
        }
      ]
    }
  ]
}