{
  "name": "di-wm-operations",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "domain-integrations/wm-operations/src",
  "projectType": "library",
  "namedInputs": {
    "backendDomain": [
      "{workspaceRoot}/apps/api/adapters/wm_operations/**/*.py",
      "{workspaceRoot}/apps/api/routes/wm_operations.py",
      "{workspaceRoot}/apps/api/routes/_databricks.py",
      "{workspaceRoot}/apps/api/shared/query_service/**/*.py"
    ],
    "default": ["{projectRoot}/**/*", "sharedGlobals", "backendDomain"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)",
      "!{projectRoot}/**/*.stories.[jt]s?(x)",
      "!{projectRoot}/src/test-setup.[jt]s?(x)"
    ]
  },
  "tags": ["scope:warehouse", "layer:integration", "type:lib"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "domain-integrations/wm-operations"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["domain-integrations/wm-operations/**/*.{ts,tsx}"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "config": "domain-integrations/wm-operations/vitest.config.ts"
      }
    }
  }
}
